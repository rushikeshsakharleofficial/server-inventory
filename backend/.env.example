DATABASE_URL=postgresql://inventory:REPLACE_ME_POSTGRES_PASSWORD@localhost:5432/server_inventory
POSTGRES_PASSWORD=REPLACE_ME_POSTGRES_PASSWORD
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_ME_STRONG_PASSWORD
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_ME_RANDOM_SECRET_KEY
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=REPLACE_ME_FERNET_KEY
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173,http://localhost:3000,http://127.0.0.1:3001
VITE_API_URL=

# Real Cloud Smoke Verification — see backend/app/cloud_smoke_verifier.py.
# All real API calls are off unless ENABLE_REAL_CLOUD_SMOKE=true; even then,
# only read-only/list calls run (REAL_CLOUD_ALLOW_CREATE is never honored).
ENABLE_REAL_CLOUD_SMOKE=false
REAL_CLOUD_READ_ONLY=true
REAL_CLOUD_ALLOW_CREATE=false
REAL_CLOUD_MAX_CALLS_PER_PROVIDER=50
REAL_CLOUD_TIMEOUT_SECONDS=20
REAL_CLOUD_PROVIDERS=aws,gcp,azure,digitalocean,linode,ovh
